# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Target chat/channel ID to send scheduled daily messages
# For a channel, use the format: @yourchannel or the numeric chat ID
CHAT_ID=your_chat_id_here

# Optional: Admin Telegram IDs (comma-separated) for admin commands
# ADMIN_TELEGRAM_IDS=123456789,987654321

# Optional: Override the cron schedule (default: 15:30 ICT / UTC+7)
# Uses node-cron format: "second minute hour day month weekday"
# CRON_SCHEDULE=30 15 * * *
